// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
    "lsp": {
        // MAKE SURE TO USE THE VUE EXTENSION VERSION 0.2.8!!
        "vue-language-server": {
            "initialization_options": {
                "typescript": {
                    "tsdk": "frontend/node_modules/typescript/lib"
                }
            }
        },
        "oxfmt": {
            "initialization_options": {
                "settings": {
                    "fmt.configPath": "frontend/oxfmt.config.ts",
                    "run": "onSave"
                }
            }
        },
        "oxlint": {
            "initialization_options": {
                "settings": {
                    "configPath": "frontend/oxlint.config.ts",
                    "run": "onSave",
                    "disableNestedConfig": false,
                    "fixKind": "safe_fix",
                    "unusedDisableDirectives": "deny"
                }
            }
        }
    },
    "languages": {
        "CSS": {
            "format_on_save": "on",
            "prettier": {
                "allowed": false
            },
            "formatter": {
                "language_server": {
                    "name": "oxfmt"
                }
            }
        },
        "GraphQL": {
            "format_on_save": "on",
            "prettier": {
                "allowed": false
            },
            "formatter": {
